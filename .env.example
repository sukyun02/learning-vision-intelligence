# .env.example — GitHub에 올려도 되는 템플릿 파일
# 실제 사용 시 이 파일을 복사해서 .env로 만들고 값을 채워넣으세요:
#   cp .env.example .env
# =============================================================================

WANDB_API_KEY=
WANDB_PROJECT=pyramidnet-cifar100
WANDB_ENTITY=

SEED=42
EPOCHS=1800
BATCH_SIZE=64
LR=0.05
WEIGHT_DECAY=0.0005
SWA_EPOCHS=450

DATA_ROOT=./data
CKPT_DIR=./checkpoints
